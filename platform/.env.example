# ==============================================================================
# Variables de entorno para Docker Compose
# Copiar a .env y ajustar según el entorno
# ==============================================================================

# ── Perfil Spring ──
SPRING_PROFILES_ACTIVE=local

# ── PostgreSQL ──
DB_HOST=localhost
DB_PORT=5432
DB_NAME=platform
DB_USER=platform
DB_PASSWORD=platform

# ── Keycloak (OIDC) — solo para perfil prod ──
# OIDC_ISSUER_URI=http://localhost:8180/realms/platform
# OIDC_JWK_SET_URI=http://localhost:8180/realms/platform/protocol/openid-connect/certs

# ── Server ──
SERVER_PORT=8080

# ── Tenants ──
APP_TENANTS=acme,globex

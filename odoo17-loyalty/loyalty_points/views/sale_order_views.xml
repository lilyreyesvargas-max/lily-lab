<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_order_form_loyalty_inherit" model="ir.ui.view">
        <field name="name">sale.order.form.loyalty.inherit</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//header" position="inside">
                <button name="action_apply_loyalty_points" type="object" string="Apply Points" invisible="state != 'draft'"/>
            </xpath>
            <xpath expr="//field[@name='payment_term_id']" position="after">
                <field name="loyalty_points_to_redeem" invisible="state != 'draft'"/>
                <field name="loyalty_discount" widget="monetary" readonly="1"/>
            </xpath>
        </field>
    </record>
</odoo>

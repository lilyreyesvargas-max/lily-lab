<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_loyalty_rule_tree" model="ir.ui.view">
        <field name="name">loyalty.rule.tree</field>
        <field name="model">loyalty.rule</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="min_amount"/>
                <field name="ratio_amount"/>
                <field name="ratio_redeem"/>
                <field name="active"/>
            </tree>
        </field>
    </record>

    <record id="view_loyalty_rule_form" model="ir.ui.view">
        <field name="name">loyalty.rule.form</field>
        <field name="model">loyalty.rule</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" placeholder="Rule Name"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="min_amount"/>
                            <field name="active"/>
                        </group>
                        <group>
                            <field name="ratio_amount"/>
                            <field name="ratio_redeem"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_loyalty_rule" model="ir.actions.act_window">
        <field name="name">Loyalty Rules</field>
        <field name="res_model">loyalty.rule</field>
        <field name="view_mode">tree,form</field>
    </record>
</odoo>

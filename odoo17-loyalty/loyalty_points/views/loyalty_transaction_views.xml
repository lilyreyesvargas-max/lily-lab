<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_loyalty_transaction_tree" model="ir.ui.view">
        <field name="name">loyalty.transaction.tree</field>
        <field name="model">loyalty.transaction</field>
        <field name="arch" type="xml">
            <tree create="false">
                <field name="date"/>
                <field name="partner_id"/>
                <field name="type"/>
                <field name="points" sum="Total Points"/>
                <field name="origin"/>
            </tree>
        </field>
    </record>

    <record id="view_loyalty_transaction_form" model="ir.ui.view">
        <field name="name">loyalty.transaction.form</field>
        <field name="model">loyalty.transaction</field>
        <field name="arch" type="xml">
            <form create="false">
                <sheet>
                    <group>
                        <group>
                            <field name="partner_id" readonly="1"/>
                            <field name="date" readonly="1"/>
                            <field name="type" readonly="1"/>
                        </group>
                        <group>
                            <field name="points" readonly="1"/>
                            <field name="origin" readonly="1"/>
                        </group>
                    </group>
                    <group string="Notes">
                        <field name="note" readonly="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_loyalty_transaction" model="ir.actions.act_window">
        <field name="name">Loyalty Transactions</field>
        <field name="res_model">loyalty.transaction</field>
        <field name="view_mode">tree,form</field>
    </record>
</odoo>

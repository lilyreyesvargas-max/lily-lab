<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="report_loyalty_summary">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="o">
                <t t-call="web.external_layout">
                    <div class="page">
                        <div class="oe_structure"/>
                        <h2>Resumen de Puntos de Fidelidad</h2>
                        <div class="row mt32 mb32">
                            <div class="col-6">
                                <strong>Cliente:</strong>
                                <p t-field="o.name"/>
                            </div>
                            <div class="col-6 text-right">
                                <strong>Puntos Disponibles:</strong>
                                <h3 t-field="o.loyalty_points"/>
                            </div>
                        </div>

                        <h3>Historial de Transacciones</h3>
                        <table class="table table-sm o_main_table">
                            <thead>
                                <tr>
                                    <th>Fecha</th>
                                    <th>Origen</th>
                                    <th>Tipo</th>
                                    <th class="text-right">Puntos</th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-foreach="env['loyalty.transaction'].search([('partner_id', '=', o.id)], order='date desc')" t-as="t">
                                    <tr>
                                        <td><span t-field="t.date"/></td>
                                        <td><span t-field="t.origin"/></td>
                                        <td><span t-field="t.type"/></td>
                                        <td class="text-right">
                                            <span t-field="t.points"/>
                                        </td>
                                    </tr>
                                </t>
                            </tbody>
                        </table>
                        <div class="oe_structure"/>
                    </div>
                </t>
            </t>
        </t>
    </template>
</odoo>

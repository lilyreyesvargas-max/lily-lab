<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Module Category -->
    <record id="module_category_loyalty" model="ir.module.category">
        <field name="name">Loyalty Management</field>
        <field name="description">Manage customer loyalty points and rules.</field>
        <field name="sequence">20</field>
    </record>

    <!-- Manager Group -->
    <record id="group_loyalty_manager" model="res.groups">
        <field name="name">Loyalty Manager</field>
        <field name="category_id" ref="module_category_loyalty"/>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        <field name="users" eval="[(4, ref('base.user_root')), (4, ref('base.user_admin'))]"/>
    </record>
</odoo>

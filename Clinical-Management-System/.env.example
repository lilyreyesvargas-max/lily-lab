# ============================================================
# Clinical Management System - Environment Variables
# cp .env.example .env  (then edit passwords before running)
# ============================================================

# --- PostgreSQL ---
POSTGRES_DB=odoo_clinic
POSTGRES_USER=odoo
POSTGRES_PASSWORD=odoo_pwd_strong
POSTGRES_PORT=5432
POSTGRES_HOST=db

# --- Odoo ---
ODOO_ADMIN_PASS=admin_local_strong

# --- Timezone ---
TZ=America/New_York

# --- EDI / Mock Clearinghouse ---
EDI_BASE_URL=http://mock-clearinghouse:18080
EDI_SFTP_HOST=sftp-sandbox
EDI_SFTP_PORT=22
EDI_SFTP_USER=ediuser
EDI_SFTP_PASS=edipass
EDI_VERBOSE=1

# --- pgAdmin (optional) ---
PGADMIN_EMAIL=admin@clinic.local
PGADMIN_PASSWORD=pgadmin_local

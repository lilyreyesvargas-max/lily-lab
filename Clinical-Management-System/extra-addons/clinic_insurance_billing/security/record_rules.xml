<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">

        <!-- ── clinic.billing.claim ───────────────────────────────────────── -->
        <!-- clinic.remittance has no company_id field, so no RLS rule needed.
             All patient-identifiable financial data is isolated at claim level. -->
        <record id="rule_billing_claim_multicompany" model="ir.rule">
            <field name="name">Clinic Billing Claim: multi-company isolation</field>
            <field name="model_id" ref="clinic_insurance_billing.model_clinic_billing_claim"/>
            <field name="domain_force">
                ['|', ('company_id', '=', False),
                      ('company_id', 'in', company_ids)]
            </field>
            <field name="global" eval="True"/>
        </record>

        <record id="rule_billing_claim_admin_all" model="ir.rule">
            <field name="name">Clinic Billing Claim: admin sees all</field>
            <field name="model_id" ref="clinic_insurance_billing.model_clinic_billing_claim"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('clinic_core.clinic_group_admin'))]"/>
        </record>

    </data>
</odoo>

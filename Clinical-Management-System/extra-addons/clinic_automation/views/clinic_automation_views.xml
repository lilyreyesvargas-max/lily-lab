<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Automation Log -->
    <record id="view_clinic_automation_log_list" model="ir.ui.view">
        <field name="name">clinic.automation.log.list</field>
        <field name="model">clinic.automation.log</field>
        <field name="arch" type="xml">
            <tree decoration-danger="result == 'error'" decoration-warning="result == 'warning'">
                <field name="create_date"/>
                <field name="job_type"/>
                <field name="company_id"/>
                <field name="result"/>
                <field name="records_processed"/>
                <field name="duration_ms"/>
                <field name="message"/>
            </tree>
        </field>
    </record>

    <record id="view_clinic_automation_log_form" model="ir.ui.view">
        <field name="name">clinic.automation.log.form</field>
        <field name="model">clinic.automation.log</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="job_type"/>
                            <field name="company_id"/>
                            <field name="result"/>
                        </group>
                        <group>
                            <field name="records_processed"/>
                            <field name="duration_ms"/>
                            <field name="create_date"/>
                        </group>
                    </group>
                    <field name="message"/>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_clinic_automation_log" model="ir.actions.act_window">
        <field name="name">Automation Logs</field>
        <field name="res_model">clinic.automation.log</field>
        <field name="view_mode">tree,form</field>
    </record>

    <!-- Automation Config -->
    <record id="view_clinic_automation_config_form" model="ir.ui.view">
        <field name="name">clinic.automation.config.form</field>
        <field name="model">clinic.automation.config</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group string="Company">
                        <field name="company_id"/>
                        <field name="active"/>
                    </group>
                    <group string="Appointment Reminders">
                        <field name="reminder_enabled"/>
                        <field name="reminder_hours_before" invisible="not reminder_enabled"/>
                    </group>
                    <group string="Stock Alerts">
                        <field name="stock_alert_enabled"/>
                        <field name="stock_min_qty" invisible="not stock_alert_enabled"/>
                    </group>
                    <group string="Expiry Alerts">
                        <field name="expiry_alert_enabled"/>
                        <field name="expiry_days_warning" invisible="not expiry_alert_enabled"/>
                    </group>
                    <group string="EDI Jobs">
                        <field name="edi_auto_send"/>
                        <field name="edi_auto_import"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_clinic_automation_config_list" model="ir.ui.view">
        <field name="name">clinic.automation.config.list</field>
        <field name="model">clinic.automation.config</field>
        <field name="arch" type="xml">
            <tree>
                <field name="company_id"/>
                <field name="active"/>
                <field name="reminder_enabled"/>
                <field name="stock_alert_enabled"/>
                <field name="expiry_alert_enabled"/>
                <field name="edi_auto_send"/>
                <field name="edi_auto_import"/>
            </tree>
        </field>
    </record>

    <record id="action_clinic_automation_config" model="ir.actions.act_window">
        <field name="name">Automation Config</field>
        <field name="res_model">clinic.automation.config</field>
        <field name="view_mode">tree,form</field>
    </record>
</odoo>

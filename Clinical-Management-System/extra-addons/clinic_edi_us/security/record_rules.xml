                      ('company_id', 'in', company_ids)]
            </field>
            <field name="global" eval="True"/>
        </record>

        <record id="rule_edi_eligibility_admin_all" model="ir.rule">
            <field name="name">Clinic EDI Eligibility: admin sees all</field>
            <field name="model_id" ref="clinic_edi_us.model_clinic_edi_eligibility_request"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('clinic_core.clinic_group_admin'))]"/>
        </record>

        <!-- ── clinic.edi.config ──────────────────────────────────────────── -->
        <record id="rule_edi_config_multicompany" model="ir.rule">
            <field name="name">Clinic EDI Config: multi-company isolation</field>
            <field name="model_id" ref="clinic_edi_us.model_clinic_edi_config"/>
            <field name="domain_force">
                ['|', ('company_id', '=', False),
                      ('company_id', 'in', company_ids)]
            </field>
            <field name="global" eval="True"/>
        </record>

        <record id="rule_edi_config_admin_all" model="ir.rule">
            <field name="name">Clinic EDI Config: admin sees all</field>

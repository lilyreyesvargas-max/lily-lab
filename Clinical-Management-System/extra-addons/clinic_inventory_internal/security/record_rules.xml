<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!-- ── clinic.supply.request ─────────────────────────────────────── -->
        <record id="rule_supply_request_multicompany" model="ir.rule">
            <field name="name">Clinic Supply Request: multi-company isolation</field>
            <field name="model_id" ref="clinic_inventory_internal.model_clinic_supply_request"/>
            <field name="domain_force">
                ['|', ('company_id', '=', False),
                      ('company_id', 'in', company_ids)]
            </field>
            <field name="global" eval="True"/>
        </record>

        <record id="rule_supply_request_admin_all" model="ir.rule">
            <field name="name">Clinic Supply Request: admin sees all</field>
            <field name="model_id" ref="clinic_inventory_internal.model_clinic_supply_request"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('clinic_core.clinic_group_admin'))]"/>
        </record>

    </data>
</odoo>

<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_clinic_supply_request_form" model="ir.ui.view">
        <field name="name">clinic.supply.request.form</field>
        <field name="model">clinic.supply.request</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_submit" string="Submit" type="object"
                            class="oe_highlight" invisible="state != 'draft'"/>
                    <button name="action_approve" string="Approve" type="object"
                            class="oe_highlight" invisible="state != 'submitted'"
                            groups="clinic_core.clinic_group_admin"/>
                    <button name="action_reject" string="Reject" type="object"
                            invisible="state != 'submitted'"
                            groups="clinic_core.clinic_group_admin"/>
                    <button name="action_create_transfer" string="Create Transfer" type="object"
                            invisible="state != 'approved'"/>
                    <button name="action_mark_consumed" string="Mark Consumed" type="object"
                            invisible="state != 'transferred'"/>
                    <button name="action_reset_draft" string="Reset" type="object"
                            invisible="state not in ['rejected']"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,submitted,approved,transferred,consumed"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" readonly="1"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="company_id"/>
                            <field name="requested_by"/>
                            <field name="request_date"/>
                            <field name="required_date"/>
                        </group>
                        <group>
                            <field name="approved_by" readonly="1"/>
                            <field name="picking_id" readonly="1"/>
                        </group>
                    </group>
                    <field name="line_ids">
                        <tree editable="bottom">
                            <field name="product_id"/>
                            <field name="quantity_requested"/>
                            <field name="quantity_approved"/>
                            <field name="uom_id" readonly="1"/>
                            <field name="notes"/>
                        </tree>
                    </field>
                    <group string="Notes"><field name="notes" nolabel="1"/></group>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <record id="view_clinic_supply_request_list" model="ir.ui.view">
        <field name="name">clinic.supply.request.list</field>
        <field name="model">clinic.supply.request</field>
        <field name="arch" type="xml">
            <tree decoration-success="state == 'consumed'" decoration-warning="state == 'approved'">
                <field name="name"/>
                <field name="company_id"/>
                <field name="requested_by"/>
                <field name="request_date"/>
                <field name="required_date"/>
                <field name="state"/>
            </tree>
        </field>
    </record>

    <record id="action_clinic_supply_request" model="ir.actions.act_window">
        <field name="name">Supply Requests</field>
        <field name="res_model">clinic.supply.request</field>
        <field name="view_mode">tree,form</field>
    </record>
</odoo>

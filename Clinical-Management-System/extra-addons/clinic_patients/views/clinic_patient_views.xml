<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_clinic_patient_form" model="ir.ui.view">
        <field name="name">clinic.patient.form</field>
        <field name="model">clinic.patient</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" placeholder="Patient Full Name"/></h1>
                        <h3><field name="ref" readonly="1"/></h3>
                    </div>
                    <group>
                        <group string="Personal Information">
                            <field name="date_of_birth"/>
                            <field name="age"/>
                            <field name="gender"/>
                            <field name="blood_type"/>
                            <field name="company_id"/>
                        </group>
                        <group string="Contact">
                            <field name="phone"/>
                            <field name="mobile"/>
                            <field name="email"/>
                        </group>
                    </group>
                    <group string="Address">
                        <field name="address" nolabel="1"/>
                    </group>
                    <notebook>
                        <page string="Insurance Policies">
                            <field name="policy_ids">
                                <tree editable="bottom">
                                    <field name="insurer_id"/>
                                    <field name="plan_id"/>
                                    <field name="policy_number"/>
                                    <field name="member_id"/>
                                    <field name="is_primary"/>
                                    <field name="effective_date"/>
                                    <field name="state"/>
                                </tree>
                            </field>
                        </page>
                        <page string="Consents">
                            <field name="consent_ids">
                                <tree editable="bottom">
                                    <field name="consent_type"/>
                                    <field name="signed_date"/>
                                    <field name="expiry_date"/>
                                    <field name="signed_by"/>
                                </tree>
                            </field>
                        </page>
                        <page string="Notes">
                            <field name="notes"/>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <record id="view_clinic_patient_list" model="ir.ui.view">
        <field name="name">clinic.patient.list</field>
        <field name="model">clinic.patient</field>
        <field name="arch" type="xml">
            <tree>
                <field name="ref"/>
                <field name="name"/>
                <field name="date_of_birth"/>
                <field name="age"/>
                <field name="gender"/>
                <field name="phone"/>
                <field name="company_id"/>
            </tree>
        </field>
    </record>

    <record id="view_clinic_patient_search" model="ir.ui.view">
        <field name="name">clinic.patient.search</field>
        <field name="model">clinic.patient</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="ref"/>
                <field name="phone"/>
                <filter string="Active" name="active" domain="[('active','=',True)]"/>
                <group expand="0" string="Group By">
                    <filter string="Gender" name="group_gender" context="{'group_by':'gender'}"/>
                    <filter string="Branch" name="group_company" context="{'group_by':'company_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_clinic_patient" model="ir.actions.act_window">
        <field name="name">Patients</field>
        <field name="res_model">clinic.patient</field>
        <field name="view_mode">tree,form</field>
    </record>

    <record id="view_clinic_patient_policy_list" model="ir.ui.view">
        <field name="name">clinic.patient.policy.list</field>
        <field name="model">clinic.patient.policy</field>
        <field name="arch" type="xml">
            <tree>
                <field name="patient_id"/>
                <field name="insurer_id"/>
                <field name="plan_id"/>
                <field name="policy_number"/>
                <field name="member_id"/>
                <field name="is_primary"/>
                <field name="state"/>
            </tree>
        </field>
    </record>

    <record id="action_clinic_patient_policy" model="ir.actions.act_window">
        <field name="name">Insurance Policies</field>
        <field name="res_model">clinic.patient.policy</field>
        <field name="view_mode">tree,form</field>
    </record>
</odoo>

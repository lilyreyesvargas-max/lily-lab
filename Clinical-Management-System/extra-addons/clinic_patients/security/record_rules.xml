<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!-- ── clinic.patient ─────────────────────────────────────────────── -->
        <!-- Global rule: every non-admin user sees only records whose
             company_id is in the set of companies allowed for that user.
             company_ids is a magic variable Odoo injects in rule domains. -->
        <record id="rule_patient_multicompany" model="ir.rule">
            <field name="name">Clinic Patient: multi-company isolation</field>
            <field name="model_id" ref="clinic_patients.model_clinic_patient"/>
            <field name="domain_force">
                ['|', ('company_id', '=', False),
                      ('company_id', 'in', company_ids)]
            </field>
            <field name="global" eval="True"/>
        </record>

        <!-- Admin override: clinic admins can see ALL branches -->
        <record id="rule_patient_admin_all" model="ir.rule">
            <field name="name">Clinic Patient: admin sees all</field>
            <field name="model_id" ref="clinic_patients.model_clinic_patient"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('clinic_core.clinic_group_admin'))]"/>
        </record>

        <!-- ── clinic.patient.policy ──────────────────────────────────────── -->
        <record id="rule_patient_policy_multicompany" model="ir.rule">
            <field name="name">Clinic Patient Policy: multi-company isolation</field>
            <field name="model_id" ref="clinic_patients.model_clinic_patient_policy"/>
            <field name="domain_force">
                ['|', ('patient_id.company_id', '=', False),
                      ('patient_id.company_id', 'in', company_ids)]
            </field>
            <field name="global" eval="True"/>
        </record>

        <record id="rule_patient_policy_admin_all" model="ir.rule">
            <field name="name">Clinic Patient Policy: admin sees all</field>
            <field name="model_id" ref="clinic_patients.model_clinic_patient_policy"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('clinic_core.clinic_group_admin'))]"/>
        </record>

        <!-- ── clinic.patient.consent ─────────────────────────────────────── -->
        <record id="rule_patient_consent_multicompany" model="ir.rule">
            <field name="name">Clinic Patient Consent: multi-company isolation</field>
            <field name="model_id" ref="clinic_patients.model_clinic_patient_consent"/>
            <field name="domain_force">
                ['|', ('patient_id.company_id', '=', False),
                      ('patient_id.company_id', 'in', company_ids)]
            </field>
            <field name="global" eval="True"/>
        </record>

        <record id="rule_patient_consent_admin_all" model="ir.rule">
            <field name="name">Clinic Patient Consent: admin sees all</field>
            <field name="model_id" ref="clinic_patients.model_clinic_patient_consent"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('clinic_core.clinic_group_admin'))]"/>
        </record>

    </data>
</odoo>

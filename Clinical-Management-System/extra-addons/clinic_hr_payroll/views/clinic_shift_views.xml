<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_clinic_shift_form" model="ir.ui.view">
        <field name="name">clinic.shift.form</field>
        <field name="model">clinic.shift</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="company_id"/>
                            <field name="active"/>
                        </group>
                        <group>
                            <field name="hour_from"/>
                            <field name="hour_to"/>
                            <field name="duration" readonly="1"/>
                        </group>
                    </group>
                    <group string="Days">
                        <field name="day_ids" widget="many2many_tags" nolabel="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_clinic_shift_list" model="ir.ui.view">
        <field name="name">clinic.shift.list</field>
        <field name="model">clinic.shift</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="company_id"/>
                <field name="hour_from"/>
                <field name="hour_to"/>
                <field name="duration"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="action_clinic_shift" model="ir.actions.act_window">
        <field name="name">Shifts</field>
        <field name="res_model">clinic.shift</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>

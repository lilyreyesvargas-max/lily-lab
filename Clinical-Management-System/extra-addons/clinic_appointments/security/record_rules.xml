<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">

        <!-- ── clinic.appointment ────────────────────────────────────────── -->
        <record id="rule_appointment_multicompany" model="ir.rule">
            <field name="name">Clinic Appointment: multi-company isolation</field>
            <field name="model_id" ref="clinic_appointments.model_clinic_appointment"/>
            <field name="domain_force">
                ['|', ('company_id', '=', False),
                      ('company_id', 'in', company_ids)]
            </field>
            <field name="global" eval="True"/>
        </record>

        <record id="rule_appointment_admin_all" model="ir.rule">
            <field name="name">Clinic Appointment: admin sees all</field>
            <field name="model_id" ref="clinic_appointments.model_clinic_appointment"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('clinic_core.clinic_group_admin'))]"/>
        </record>

    </data>
</odoo>

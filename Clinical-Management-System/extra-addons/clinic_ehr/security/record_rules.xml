<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">

        <!-- ── clinic.ehr.encounter ───────────────────────────────────────── -->
        <record id="rule_encounter_multicompany" model="ir.rule">
            <field name="name">Clinic Encounter: multi-company isolation</field>
            <field name="model_id" ref="clinic_ehr.model_clinic_ehr_encounter"/>
            <field name="domain_force">
                ['|', ('company_id', '=', False),
                      ('company_id', 'in', company_ids)]
            </field>
            <field name="global" eval="True"/>
        </record>

        <record id="rule_encounter_admin_all" model="ir.rule">
            <field name="name">Clinic Encounter: admin sees all</field>
            <field name="model_id" ref="clinic_ehr.model_clinic_ehr_encounter"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('clinic_core.clinic_group_admin'))]"/>
        </record>

        <!-- ── clinic.ehr.diagnosis ───────────────────────────────────────── -->
        <record id="rule_diagnosis_multicompany" model="ir.rule">
            <field name="name">Clinic Diagnosis: multi-company isolation</field>
            <field name="model_id" ref="clinic_ehr.model_clinic_ehr_diagnosis"/>
            <field name="domain_force">
                ['|', ('encounter_id.company_id', '=', False),
                      ('encounter_id.company_id', 'in', company_ids)]
            </field>
            <field name="global" eval="True"/>
        </record>

        <record id="rule_diagnosis_admin_all" model="ir.rule">
            <field name="name">Clinic Diagnosis: admin sees all</field>
            <field name="model_id" ref="clinic_ehr.model_clinic_ehr_diagnosis"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('clinic_core.clinic_group_admin'))]"/>
        </record>

    </data>
</odoo>

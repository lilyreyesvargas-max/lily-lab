<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!-- ── clinic.ehr.encounter.gynecology ────────────────────────────── -->
        <record id="rule_gynecology_multicompany" model="ir.rule">
            <field name="name">Clinic Gynecology: multi-company isolation</field>
            <field name="model_id" ref="clinic_ehr.model_clinic_ehr_encounter_gynecology"/>
            <field name="domain_force">
                ['|', ('encounter_id.company_id', '=', False),
                      ('encounter_id.company_id', 'in', company_ids)]
            </field>
            <field name="global" eval="True"/>
        </record>

        <record id="rule_gynecology_admin_all" model="ir.rule">
            <field name="name">Clinic Gynecology: admin sees all</field>
            <field name="model_id" ref="clinic_ehr.model_clinic_ehr_encounter_gynecology"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('clinic_core.clinic_group_admin'))]"/>
        </record>


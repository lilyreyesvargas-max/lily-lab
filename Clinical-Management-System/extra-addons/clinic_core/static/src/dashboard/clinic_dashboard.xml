<?xml version="1.0" encoding="utf-8"?>
<templates xml:space="preserve">
    <t t-name="clinic_core.ClinicDashboard">
        <div class="o_action clinic-dashboard-root">
            <div class="container-fluid mt-4">

                <!-- ═══════════════════════════════════════════════════ Header -->
                <div class="row mb-3">
                    <div class="col-12 d-flex align-items-center justify-content-between">
                        <h2 class="text-primary mb-0">
                            <i class="fa fa-hospital-o me-2"/>
                            Clinical Dashboard
                        </h2>
                        <span t-att-class="'badge fs-6 clinic-role-badge clinic-role-' + state.role"
                              t-esc="state.roleLabel"/>
                    </div>
                    <div class="col-12"><hr/></div>
                </div>

                <!-- ═══════════════════════════════════════════════════ KPI Cards -->
                <div class="row g-3 mb-4">

                    <!-- KPI 1 -->
                    <div class="col-md-3">
                        <div t-att-class="'card text-center shadow-sm h-100 clinic-kpi-card border-' + state.kpi1Color"
                             t-on-click="_kpi1Click">
                            <div class="card-body">
                                <i t-att-class="'fa fa-2x mb-2 text-' + state.kpi1Color + ' ' + state.kpi1Icon"/>
                                <h5 class="card-title text-muted" t-esc="state.kpi1Label"/>
                                <h2 t-att-class="'fw-bold text-' + state.kpi1Color" t-esc="state.kpi1"/>
                                <small class="text-muted" t-esc="state.kpi1Sub"/>
                            </div>
                        </div>
                    </div>

                    <!-- KPI 2 -->
                    <div class="col-md-3">
                        <div t-att-class="'card text-center shadow-sm h-100 clinic-kpi-card border-' + state.kpi2Color"
                             t-on-click="_kpi2Click">
                            <div class="card-body">
                                <i t-att-class="'fa fa-2x mb-2 text-' + state.kpi2Color + ' ' + state.kpi2Icon"/>
                                <h5 class="card-title text-muted" t-esc="state.kpi2Label"/>
                                <h2 t-att-class="'fw-bold text-' + state.kpi2Color" t-esc="state.kpi2"/>
                                <small class="text-muted" t-esc="state.kpi2Sub"/>
                            </div>
                        </div>
                    </div>

                    <!-- KPI 3 -->
                    <div class="col-md-3">
                        <div t-att-class="'card text-center shadow-sm h-100 clinic-kpi-card border-' + state.kpi3Color"
                             t-on-click="_kpi3Click">
                            <div class="card-body">
                                <i t-att-class="'fa fa-2x mb-2 text-' + state.kpi3Color + ' ' + state.kpi3Icon"/>
                                <h5 class="card-title text-muted" t-esc="state.kpi3Label"/>
                                <h2 t-att-class="'fw-bold text-' + state.kpi3Color" t-esc="state.kpi3"/>
                                <small class="text-muted" t-esc="state.kpi3Sub"/>
                            </div>
                        </div>
                    </div>

                    <!-- KPI 4 -->
                    <div class="col-md-3">
                        <div t-att-class="'card text-center shadow-sm h-100 clinic-kpi-card border-' + state.kpi4Color"
                             t-on-click="_kpi4Click">
                            <div class="card-body">
                                <i t-att-class="'fa fa-2x mb-2 text-' + state.kpi4Color + ' ' + state.kpi4Icon"/>
                                <h5 class="card-title text-muted" t-esc="state.kpi4Label"/>
                                <h2 t-att-class="'fw-bold text-' + state.kpi4Color" t-esc="state.kpi4"/>
                                <small class="text-muted" t-esc="state.kpi4Sub"/>
                            </div>
                        </div>
                    </div>

                </div>

                <!-- ═══════════════════════════════════════════════════ Charts Row 1 -->
                <div class="row g-3 mb-3">

                    <!-- Chart A -->
                    <div class="col-md-6">
                        <div class="card shadow-sm clinic-chart-card">
                            <div class="card-header fw-bold d-flex align-items-center">
                                <i t-att-class="'fa me-2 text-primary ' + (state.chartAType === 'doughnut' ? 'fa-pie-chart' : 'fa-bar-chart')"/>
                                <span t-esc="state.chartATitle"/>
                            </div>
                            <div class="card-body d-flex align-items-center justify-content-center">
                                <canvas t-ref="chartA" style="max-height:260px; width:100%;"/>
                            </div>
                        </div>
                    </div>

                    <!-- Chart B -->
                    <div class="col-md-6">
                        <div class="card shadow-sm clinic-chart-card">
                            <div class="card-header fw-bold d-flex align-items-center">
                                <i t-att-class="'fa me-2 text-primary ' + (state.chartBType === 'doughnut' ? 'fa-pie-chart' : 'fa-bar-chart')"/>
                                <span t-esc="state.chartBTitle"/>
                            </div>
                            <div class="card-body d-flex align-items-center justify-content-center">
                                <canvas t-ref="chartB" style="max-height:260px; width:100%;"/>
                            </div>
                        </div>
                    </div>

                </div>

                <!-- ═══════════════════════════════════════════════════ Charts Row 2 -->
                <div class="row g-3">

                    <!-- Chart C -->
                    <div class="col-md-6">
                        <div class="card shadow-sm clinic-chart-card">
                            <div class="card-header fw-bold d-flex align-items-center">
                                <i t-att-class="'fa me-2 text-primary ' + (state.chartCType === 'doughnut' ? 'fa-pie-chart' : 'fa-bar-chart')"/>
                                <span t-esc="state.chartCTitle"/>
                            </div>
                            <div class="card-body d-flex align-items-center justify-content-center">
                                <canvas t-ref="chartC" style="max-height:260px; width:100%;"/>
                            </div>
                        </div>
                    </div>

                    <!-- Chart D -->
                    <div class="col-md-6">
                        <div class="card shadow-sm clinic-chart-card">
                            <div class="card-header fw-bold d-flex align-items-center">
                                <i t-att-class="'fa me-2 text-primary ' + (state.chartDType === 'doughnut' ? 'fa-pie-chart' : 'fa-bar-chart')"/>
                                <span t-esc="state.chartDTitle"/>
                            </div>
                            <div class="card-body d-flex align-items-center justify-content-center">
                                <canvas t-ref="chartD" style="max-height:260px; width:100%;"/>
                            </div>
                        </div>
                    </div>

                </div>

            </div>
        </div>
    </t>
</templates>

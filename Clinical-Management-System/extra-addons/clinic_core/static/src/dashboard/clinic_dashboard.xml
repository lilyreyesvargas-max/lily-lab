<?xml version="1.0" encoding="utf-8"?>
<templates xml:space="preserve">
    <t t-name="clinic_core.ClinicDashboard">
        <div class="o_action">
            <div class="container-fluid mt-4">
                <div class="row mb-3">
                    <div class="col-12">
                        <h2 class="text-primary">
                            <i class="fa fa-hospital-o me-2"/>
                            Clinical Management Dashboard
                        </h2>
                        <hr/>
                    </div>
                </div>
                <div class="row g-3">
                    <div class="col-md-3">
                        <div class="card text-center shadow-sm h-100 cursor-pointer border-primary"
                             t-on-click="openPatients" style="cursor:pointer">
                            <div class="card-body">
                                <i class="fa fa-users fa-2x text-primary mb-2"/>
                                <h5 class="card-title text-muted">Patients</h5>
                                <h2 class="text-primary fw-bold"><t t-esc="state.patientCount"/></h2>
                                <small class="text-muted">Total registered</small>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="card text-center shadow-sm h-100 cursor-pointer border-info"
                             t-on-click="openAppointments" style="cursor:pointer">
                            <div class="card-body">
                                <i class="fa fa-calendar fa-2x text-info mb-2"/>
                                <h5 class="card-title text-muted">Appointments</h5>
                                <h2 class="text-info fw-bold"><t t-esc="state.appointmentCount"/></h2>
                                <small class="text-muted">Confirmed</small>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="card text-center shadow-sm h-100 cursor-pointer border-warning"
                             t-on-click="openClaims" style="cursor:pointer">
                            <div class="card-body">
                                <i class="fa fa-file-text fa-2x text-warning mb-2"/>
                                <h5 class="card-title text-muted">Claims</h5>
                                <h2 class="text-warning fw-bold"><t t-esc="state.claimCount"/></h2>
                                <small class="text-muted">Draft pending</small>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="card text-center shadow-sm h-100 cursor-pointer border-success"
                             t-on-click="openRemittances" style="cursor:pointer">
                            <div class="card-body">
                                <i class="fa fa-dollar fa-2x text-success mb-2"/>
                                <h5 class="card-title text-muted">Remittances</h5>
                                <h2 class="text-success fw-bold"><t t-esc="state.pendingRemittances"/></h2>
                                <small class="text-muted">Pending ERA</small>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </t>
</templates>

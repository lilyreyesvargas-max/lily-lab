<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_clinic_icd10_form" model="ir.ui.view">
        <field name="name">clinic.icd10.form</field>
        <field name="model">clinic.icd10</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="code"/>
                        <field name="description"/>
                        <field name="category"/>
                        <field name="active"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_clinic_icd10_list" model="ir.ui.view">
        <field name="name">clinic.icd10.list</field>
        <field name="model">clinic.icd10</field>
        <field name="arch" type="xml">
            <tree>
                <field name="code"/>
                <field name="description"/>
                <field name="category"/>
                <field name="active"/>
            </tree>
        </field>
    </record>

    <record id="view_clinic_icd10_search" model="ir.ui.view">
        <field name="name">clinic.icd10.search</field>
        <field name="model">clinic.icd10</field>
        <field name="arch" type="xml">
            <search>
                <field name="code"/>
                <field name="description"/>
                <field name="category"/>
                <filter string="Active" name="active" domain="[('active','=',True)]"/>
                <group expand="0" string="Group By">
                    <filter string="Category" name="group_category" context="{'group_by':'category'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_clinic_icd10" model="ir.actions.act_window">
        <field name="name">ICD-10 Codes</field>
        <field name="res_model">clinic.icd10</field>
        <field name="view_mode">tree,form</field>
    </record>
</odoo>

<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_clinic_config_form" model="ir.ui.view">
        <field name="name">clinic.config.form</field>
        <field name="model">clinic.config</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="clinic_code"/>
                        <field name="company_id"/>
                    </group>
                    <group string="Specialties">
                        <field name="specialty_ids" widget="many2many_tags"/>
                    </group>
                    <group string="Notes">
                        <field name="notes"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_clinic_config_list" model="ir.ui.view">
        <field name="name">clinic.config.list</field>
        <field name="model">clinic.config</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="clinic_code"/>
                <field name="company_id"/>
            </list>
        </field>
    </record>

    <record id="action_clinic_config" model="ir.actions.act_window">
        <field name="name">Clinic Configuration</field>
        <field name="res_model">clinic.config</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>

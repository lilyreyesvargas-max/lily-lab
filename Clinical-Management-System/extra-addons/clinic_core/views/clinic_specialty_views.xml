<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_clinic_specialty_form" model="ir.ui.view">
        <field name="name">clinic.specialty.form</field>
        <field name="model">clinic.specialty</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="code"/>
                        <field name="sequence"/>
                        <field name="color"/>
                        <field name="active"/>
                    </group>
                    <group><field name="description"/></group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_clinic_specialty_list" model="ir.ui.view">
        <field name="name">clinic.specialty.list</field>
        <field name="model">clinic.specialty</field>
        <field name="arch" type="xml">
            <list>
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="code"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="action_clinic_specialty" model="ir.actions.act_window">
        <field name="name">Specialties</field>
        <field name="res_model">clinic.specialty</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
